{
  "tasks": {
    "check": "deno fmt --check src scripts deno.json README.md && deno lint src scripts && deno check src/*.ts src/core/*.ts src/commands/*.ts scripts/*.ts",
    "test": "deno test --allow-read --allow-write --allow-env",
    "fmt": "deno fmt src scripts deno.json README.md",
    "lint": "deno lint src scripts",
    "compile": "deno compile --allow-env --allow-read --allow-write --allow-run --output gistan src/main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/cli": "jsr:@std/cli@^1.0.22",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.22/parse-args",
    "@std/path": "jsr:@std/path@^1",
    "@std/toml": "jsr:@std/toml@^1"
  }
}
