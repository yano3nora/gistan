{
  "tasks": {
    "check": "deno fmt --check src deno.json README.md && deno lint src && deno check src/main.ts src/main_test.ts",
    "test": "deno test",
    "fmt": "deno fmt src deno.json README.md",
    "lint": "deno lint src",
    "compile": "deno compile --allow-env --allow-read --output gistan src/main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/cli": "jsr:@std/cli@^1.0.22",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.22/parse-args"
  }
}
